# ───────────────────────────────────────────
# App
# ───────────────────────────────────────────
APP_NAME=OSS Sentinel
APP_ENV=development                         # development | production
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ───────────────────────────────────────────
# MongoDB
# ───────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017       # Atlas: mongodb+srv://...
MONGODB_DB_NAME=oss_sentinel

# ───────────────────────────────────────────
# Neo4j AuraDB
# ───────────────────────────────────────────
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ───────────────────────────────────────────
# Neo4j Aura Agent
# ───────────────────────────────────────────
AURA_CLIENT_ID=
AURA_CLIENT_SECRET=
AURA_AGENT_ENDPOINT=https://api.neo4j.io/v1beta/agents/<agent-id>/query

# ───────────────────────────────────────────
# GitHub (personal access token)
# Scopes needed: public_repo (read-only)
# ───────────────────────────────────────────
GITHUB_TOKEN=

# ───────────────────────────────────────────
# CORS — comma-separated allowed origins
# ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
